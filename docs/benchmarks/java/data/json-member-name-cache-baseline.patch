+    private static ForyJson buildJson(boolean cacheEnabled) {
+      ForyJsonBuilder builder =
+          ForyJson.builder().withConcurrencyLevel(1).withAsyncCompilation(false);
+      if (!cacheEnabled) {
+        try {
+          ForyJsonBuilder.class.getMethod("withMaxCachedMemberNames", int.class).invoke(builder, 0);
+        } catch (NoSuchMethodException ignored) {
+          // A runtime from before member-name caching is already equivalent to disabled caching.
+        } catch (IllegalAccessException | InvocationTargetException e) {
+          throw new IllegalStateException("Unable to disable member-name caching", e);
+        }
+      }
+      return builder.build();
